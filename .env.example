# ============================================================
# AURA — Переменные окружения (шаблон)
# Копировать в .env и заполнить
# ============================================================

# --- DeepSeek v4 (ОСНОВНОЙ МОЗГ) ---
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY_BACKUP=sk-your-backup-key-here

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# --- Локальная модель (Ollama, опционально) ---
# OLLAMA_API_KEY=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Голос: Распознавание (Speech-to-Text) ---
STT_ENGINE=vosk
VOSK_MODEL_PATH=models/vosk-model-small-ru-0.22

# --- Голос: Синтез (Text-to-Speech) ---
TTS_ENGINE=edge_tts
TTS_VOICE=ru-RU-SvetlanaNeural
TTS_RATE=160

# --- Погода (OpenWeatherMap) ---
OPENWEATHERMAP_API_KEY=your-key-here

# --- Google Calendar ---
# GOOGLE_CALENDAR_API_KEY=your-key-here
